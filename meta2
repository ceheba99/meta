          alcance: parseInt(row['Alcance'] || row.alcance || 0),
          clicsEnlace: parseInt(row['Clics en el enlace'] || row.clicsEnlace || row.clics || 0),
          tipoResultado: row['Tipo de resultado'] || row.tipoResultado || '',
          resultados: parseInt(row['Resultados'] || row.resultados || 0),
          nuevosContactos: parseInt(row['Nuevos contactos de mensajes'] || row.nuevosContactos || row.contactos || 0),
          objetivo: row['Objetivo'] || row.objetivo || '',
          costePorResultado: parseFloat(String(row['Coste por resultado'] || row.costePorResultado || 0).replace(/[$,]/g, '')),
          importeGastado: parseFloat(String(row['Importe gastado (MXN)'] || row.importeGastado || row.gasto || 0).replace(/[$,]/g, '')),
          inicioInforme: row['Inicio del informe'] || row.inicioInforme || '',
          finInforme: row['Fin del informe'] || row.finInforme || ''
        })).filter(d => d.nombre);
        
        setPeriodo(dataProcesada);
        setLoading(false);
      },
      error: (error) => {
        console.error('Error al procesar archivo:', error);
        alert('Error al procesar el archivo. Asegúrate de que sea un CSV válido.');
        setLoading(false);
      }
