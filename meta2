import React, { useState, useMemo, useRef } from 'react';
import {
  BarChart, Bar, XAxis, YAxis, 
  CartesianGrid, Tooltip, Legend, ResponsiveContainer, PieChart, Pie, Cell
} from 'recharts';
import { TrendingUp, TrendingDown, Eye, MousePointerClick, DollarSign, Target, Users, MessageCircle, ArrowUpCircle, ArrowDownCircle, Upload, Trash2, Download } from 'lucide-react';
import Papa from 'papaparse';

const ComparadorCampanasMeta = () => {
  const [periodo1Data, setPeriodo1Data] = useState([]);
  const [periodo2Data, setPeriodo2Data] = useState([]);
  const [loading, setLoading] = useState(false);
  const [exportandoPDF, setExportandoPDF] = useState(false);
  const reporteRef = useRef(null);

  const formatCurrency = (value) => {
    return new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN' }).format(value);
  };

  const formatNumber = (value) => {
    return new Intl.NumberFormat('es-MX').format(Math.round(value));
  };

  const formatPercent = (value) => {
    return `${value}%`;
  };

  const calcularVariacion = (actual, anterior) => {
    if (anterior === 0) return actual > 0 ? 100 : 0;
    return ((actual - anterior) / anterior * 100).toFixed(1);
  };

  const parseNumero = (valor) => {
    if (typeof valor === 'number') return Number.isFinite(valor) ? valor : 0;
    if (valor === null || valor === undefined) return 0;
    const normalizado = String(valor).replace(/[^\d,.-]/g, '').replace(/,/g, '');
    const numero = Number.parseFloat(normalizado);
    return Number.isFinite(numero) ? numero : 0;
  };

  const procesarArchivo = (file, setPeriodo) => {
    setLoading(true);
    Papa.parse(file, {
      header: true,
      dynamicTyping: true,
      skipEmptyLines: true,
      complete: (results) => {
        const dataProcesada = results.data.map(row => ({
          nombre: row['Nombre de la campaña'] || row.nombre || '',
          visualizaciones: parseNumero(row['Visualizaciones'] || row.visualizaciones || 0),
          alcance: parseNumero(row['Alcance'] || row.alcance || 0),
          clicsEnlace: parseNumero(row['Clics en el enlace'] || row.clicsEnlace || row.clics || 0),
          tipoResultado: row['Tipo de resultado'] || row.tipoResultado || '',
          resultados: parseNumero(row['Resultados'] || row.resultados || 0),
          nuevosContactos: parseNumero(row['Nuevos contactos de mensajes'] || row['Nuevos contactos'] || row.nuevosContactos || row.contactos || 0),
          objetivo: row['Objetivo'] || row.objetivo || '',
          costePorResultado: parseNumero(row['Coste por resultado'] || row.costePorResultado || 0),
          importeGastado: parseNumero(row['Importe gastado (MXN)'] || row.importeGastado || row.gasto || 0),
          inicioInforme: row['Inicio del informe'] || row.inicioInforme || '',
          finInforme: row['Fin del informe'] || row.finInforme || ''
        })).filter(d => d.nombre);
        
        setPeriodo(dataProcesada);
        setLoading(false);
      },
      error: (error) => {
        console.error('Error al procesar archivo:', error);
        alert('Error al procesar el archivo. Asegúrate de que sea un CSV válido.');
        setLoading(false);
      }
    });
  };

  const handleFileUpload = (event, periodo) => {
    const file = event.target.files[0];
    if (file) {
      procesarArchivo(file, periodo === 1 ? setPeriodo1Data : setPeriodo2Data);
    }
  };

  const limpiarDatos = (periodo) => {
    if (periodo === 1) setPeriodo1Data([]);
    else setPeriodo2Data([]);
  };

  const totalesPeriodo1 = useMemo(() => {
    return periodo1Data.reduce((acc, c) => ({
      visualizaciones: acc.visualizaciones + c.visualizaciones,
      alcance: acc.alcance + c.alcance,
      clics: acc.clics + c.clicsEnlace,
      resultados: acc.resultados + c.resultados,
      contactos: acc.contactos + c.nuevosContactos,
      gasto: acc.gasto + c.importeGastado
    }), { visualizaciones: 0, alcance: 0, clics: 0, resultados: 0, contactos: 0, gasto: 0 });
  }, [periodo1Data]);

  const totalesPeriodo2 = useMemo(() => {
    return periodo2Data.reduce((acc, c) => ({
      visualizaciones: acc.visualizaciones + c.visualizaciones,
      alcance: acc.alcance + c.alcance,
      clics: acc.clics + c.clicsEnlace,
      resultados: acc.resultados + c.resultados,
      contactos: acc.contactos + c.nuevosContactos,
      gasto: acc.gasto + c.importeGastado
    }), { visualizaciones: 0, alcance: 0, clics: 0, resultados: 0, contactos: 0, gasto: 0 });
  }, [periodo2Data]);

  const metricasP1 = useMemo(() => ({
    ...totalesPeriodo1,
    costePorResultado: totalesPeriodo1.resultados > 0 ? (totalesPeriodo1.gasto / totalesPeriodo1.resultados).toFixed(2) : 0,
    ctr: totalesPeriodo1.visualizaciones > 0 ? ((totalesPeriodo1.clics / totalesPeriodo1.visualizaciones) * 100).toFixed(2) : 0,
    tasaConversion: totalesPeriodo1.clics > 0 ? ((totalesPeriodo1.resultados / totalesPeriodo1.clics) * 100).toFixed(2) : 0
  }), [totalesPeriodo1]);

  const metricasP2 = useMemo(() => ({
    ...totalesPeriodo2,
    costePorResultado: totalesPeriodo2.resultados > 0 ? (totalesPeriodo2.gasto / totalesPeriodo2.resultados).toFixed(2) : 0,
    ctr: totalesPeriodo2.visualizaciones > 0 ? ((totalesPeriodo2.clics / totalesPeriodo2.visualizaciones) * 100).toFixed(2) : 0,
    tasaConversion: totalesPeriodo2.clics > 0 ? ((totalesPeriodo2.resultados / totalesPeriodo2.clics) * 100).toFixed(2) : 0
  }), [totalesPeriodo2]);

  const imprimirPDF = () => {
    window.print();
  };

  const cargarLibreriaHtml2Pdf = () => {
    if (window.html2pdf) return Promise.resolve(window.html2pdf);

    const scriptExistente = document.querySelector('script[data-html2pdf="true"]');
    if (scriptExistente) {
      return new Promise((resolve, reject) => {
        scriptExistente.addEventListener('load', () => resolve(window.html2pdf), { once: true });
        scriptExistente.addEventListener('error', () => reject(new Error('No se pudo cargar html2pdf.js')), { once: true });
      });
    }

    return new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = 'https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js';
      script.async = true;
      script.dataset.html2pdf = 'true';
      script.onload = () => resolve(window.html2pdf);
      script.onerror = () => reject(new Error('No se pudo cargar html2pdf.js'));
      document.body.appendChild(script);
    });
  };

  const descargarReportePDF = async () => {
    if (exportandoPDF) return;

    try {
      if (!hayDatos || !reporteRef.current) {
        alert('⚠️ No hay datos para generar el PDF.');
        return;
      }

      setExportandoPDF(true);
      const html2pdf = await cargarLibreriaHtml2Pdf();
      const opciones = {
        margin: [8, 8, 8, 8],
        filename: `reporte_campanas_meta_${new Date().toISOString().split('T')[0]}.pdf`,
        image: { type: 'png', quality: 1 },
        html2canvas: {
          scale: 2,
          useCORS: true,
          scrollY: 0,
          ignoreElements: (element) => element.classList?.contains('no-print')
        },
        jsPDF: {
          unit: 'mm',
          format: 'a4',
          orientation: 'portrait'
        },
        pagebreak: { mode: ['css', 'legacy'] }
      };

      await html2pdf().set(opciones).from(reporteRef.current).save();
      alert('✅ PDF generado y descargado correctamente.');
    } catch (error) {
      console.error('Error:', error);
      alert('❌ Error al generar el PDF. Revisa tu conexión e intenta de nuevo.');
    } finally {
      setExportandoPDF(false);
    }
  };
  const datosGraficoComparacion = useMemo(() => [
    { metrica: 'Visualizaciones', 'Período 1': totalesPeriodo1.visualizaciones, 'Período 2': totalesPeriodo2.visualizaciones },
    { metrica: 'Alcance', 'Período 1': totalesPeriodo1.alcance, 'Período 2': totalesPeriodo2.alcance },
    { metrica: 'Clics', 'Período 1': totalesPeriodo1.clics, 'Período 2': totalesPeriodo2.clics },
    { metrica: 'Resultados', 'Período 1': totalesPeriodo1.resultados, 'Período 2': totalesPeriodo2.resultados },
    { metrica: 'Contactos', 'Período 1': totalesPeriodo1.contactos, 'Período 2': totalesPeriodo2.contactos }
  ], [totalesPeriodo1, totalesPeriodo2]);

  const todasCampanas = useMemo(() => [
    ...periodo1Data.map(c => ({...c, periodo: 'Período 1'})),
    ...periodo2Data.map(c => ({...c, periodo: 'Período 2'}))
  ], [periodo1Data, periodo2Data]);

  const hayDatos = periodo1Data.length > 0 || periodo2Data.length > 0;

  const COLORS = ['#3b82f6', '#8b5cf6', '#ec4899', '#f59e0b', '#10b981'];

  const MetricCard = ({ title, value1, value2, icon: Icon, format = 'number', invertColors = false }) => {
    const variacion = calcularVariacion(value2, value1);
    const isPositive = parseFloat(variacion) > 0;
    const showPositive = invertColors ? !isPositive : isPositive;
    
    return (
      <div className="bg-white rounded-xl shadow-lg border border-gray-200 p-6 hover:shadow-xl transition-shadow">
        <div className="flex items-center justify-between mb-4">
          <h3 className="text-sm font-medium text-gray-600">{title}</h3>
          <Icon className="w-5 h-5 text-blue-500" />
        </div>
        <div className="space-y-3">
          <div>
            <div className="text-xs text-gray-500 mb-1">Período 1</div>
            <div className="text-2xl font-bold text-gray-800">
              {format === 'currency' ? formatCurrency(value1) : 
               format === 'percent' ? formatPercent(value1) : formatNumber(value1)}
            </div>
          </div>
          <div>
            <div className="text-xs text-gray-500 mb-1">Período 2</div>
            <div className="text-2xl font-bold text-gray-800">
              {format === 'currency' ? formatCurrency(value2) : 
               format === 'percent' ? formatPercent(value2) : formatNumber(value2)}
            </div>
          </div>
          <div className={`flex items-center gap-2 text-sm font-semibold ${showPositive ? 'text-green-600' : 'text-red-600'}`}>
            {showPositive ? <ArrowUpCircle className="w-4 h-4" /> : <ArrowDownCircle className="w-4 h-4" />}
            <span>{Math.abs(parseFloat(variacion))}% {showPositive ? 'mejora' : 'baja'}</span>
          </div>
        </div>
      </div>
    );
  };

  return (
    <div ref={reporteRef} className="min-h-screen bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 p-8">
      <style>{`
        @media print {
          body { 
            margin: 0;
            background: white !important;
          }
          .no-print { 
            display: none !important; 
          }
          .print-break { 
            page-break-after: always; 
          }
          .bg-gradient-to-br {
            background: white !important;
          }
          * {
            print-color-adjust: exact;
            -webkit-print-color-adjust: exact;
          }
          @page { 
            margin: 1.5cm;
            size: A4;
          }
          table {
            page-break-inside: avoid;
          }
          .bg-white {
            box-shadow: none !important;
          }
        }
      `}</style>
      
      <div className="bg-white rounded-xl shadow-lg border border-gray-200 p-6 mb-8 no-print">
        <div className="flex items-center justify-between flex-wrap gap-4">
          <div>
            <h1 className="text-3xl font-bold text-gray-800 flex items-center">
              <Target className="w-8 h-8 mr-3 text-blue-600" />
              Comparador de Campañas Meta Ads
            </h1>
            <p className="text-gray-600 mt-2">Sube tus archivos CSV para comparar períodos</p>
          </div>
          {hayDatos && (
            <div className="flex gap-2">
              <button
                onClick={imprimirPDF}
                className="flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-red-600 to-pink-600 text-white rounded-lg hover:from-red-700 hover:to-pink-700 transition-all shadow-lg hover:shadow-xl transform hover:scale-105"
              >
                <Download className="w-5 h-5" />
                Imprimir/PDF
              </button>
              <button
                onClick={descargarReportePDF}
                disabled={exportandoPDF}
                className={`flex items-center gap-2 px-6 py-3 text-white rounded-lg transition-all shadow-lg hover:shadow-xl ${exportandoPDF ? 'bg-gray-400 cursor-not-allowed' : 'bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 transform hover:scale-105'}`}
              >
                <Download className="w-5 h-5" />
                {exportandoPDF ? 'Generando PDF...' : 'Descargar PDF'}
              </button>
            </div>
          )}
        </div>
      </div>

      {/* Zona de carga de archivos */}
      <div className="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8 no-print">
        <div className="bg-white rounded-xl shadow-lg border-2 border-dashed border-gray-300 p-8 hover:border-blue-500 transition-colors">
          <div className="text-center">
            <Upload className="w-12 h-12 mx-auto mb-4 text-blue-500" />
            <h3 className="text-lg font-semibold text-gray-800 mb-2">Período 1</h3>
            <p className="text-sm text-gray-600 mb-4">
              {periodo1Data.length > 0 ? `${periodo1Data.length} campañas cargadas` : 'Sube archivo CSV del primer período'}
            </p>
            <input
              type="file"
              accept=".csv,.xlsx,.xls"
              onChange={(e) => handleFileUpload(e, 1)}
              className="hidden"
              id="file-periodo-1"
            />
            <label
              htmlFor="file-periodo-1"
              className="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg cursor-pointer hover:bg-blue-700 transition-colors"
            >
              <Upload className="w-4 h-4 mr-2" />
              Seleccionar archivo
            </label>
            {periodo1Data.length > 0 && (
              <button
                onClick={() => limpiarDatos(1)}
                className="ml-2 inline-flex items-center px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors"
              >
                <Trash2 className="w-4 h-4 mr-2" />
                Limpiar
              </button>
            )}
          </div>
        </div>

        <div className="bg-white rounded-xl shadow-lg border-2 border-dashed border-gray-300 p-8 hover:border-purple-500 transition-colors">
          <div className="text-center">
            <Upload className="w-12 h-12 mx-auto mb-4 text-purple-500" />
            <h3 className="text-lg font-semibold text-gray-800 mb-2">Período 2</h3>
            <p className="text-sm text-gray-600 mb-4">
              {periodo2Data.length > 0 ? `${periodo2Data.length} campañas cargadas` : 'Sube archivo CSV del segundo período'}
            </p>
            <input
              type="file"
              accept=".csv,.xlsx,.xls"
              onChange={(e) => handleFileUpload(e, 2)}
              className="hidden"
              id="file-periodo-2"
            />
            <label
              htmlFor="file-periodo-2"
              className="inline-flex items-center px-4 py-2 bg-purple-600 text-white rounded-lg cursor-pointer hover:bg-purple-700 transition-colors"
            >
              <Upload className="w-4 h-4 mr-2" />
              Seleccionar archivo
            </label>
            {periodo2Data.length > 0 && (
              <button
                onClick={() => limpiarDatos(2)}
                className="ml-2 inline-flex items-center px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors"
              >
                <Trash2 className="w-4 h-4 mr-2" />
                Limpiar
              </button>
            )}
          </div>
        </div>
      </div>

      {/* Instrucciones */}
      <div className="bg-blue-50 border border-blue-200 rounded-xl p-6 mb-8 no-print">
        <h3 className="font-semibold text-blue-900 mb-2">📋 Formato del CSV</h3>
        <p className="text-sm text-blue-800 mb-3">Tu archivo CSV debe tener estas columnas:</p>
        <div className="grid grid-cols-2 md:grid-cols-4 gap-2 text-xs text-blue-700">
          <div>• Nombre de la campaña</div>
          <div>• Visualizaciones</div>
          <div>• Alcance</div>
          <div>• Clics en el enlace</div>
          <div>• Tipo de resultado</div>
          <div>• Resultados</div>
          <div>• Nuevos contactos</div>
          <div>• Objetivo</div>
          <div>• Coste por resultado</div>
          <div>• Importe gastado</div>
          <div>• Inicio del informe</div>
          <div>• Fin del informe</div>
        </div>
      </div>

      {loading && (
        <div className="text-center py-8 no-print">
          <div className="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600"></div>
          <p className="mt-4 text-gray-600">Procesando datos...</p>
        </div>
      )}

      {!hayDatos && !loading && (
        <div className="text-center py-16 no-print">
          <Target className="w-16 h-16 mx-auto text-gray-400 mb-4" />
          <h3 className="text-xl font-semibold text-gray-700 mb-2">No hay datos cargados</h3>
          <p className="text-gray-600">Sube archivos CSV para comenzar el análisis</p>
        </div>
      )}

      {hayDatos && !loading && (
        <>
          {/* Título para impresión */}
          <div className="hidden print:block text-center mb-8">
            <h1 className="text-3xl font-bold text-gray-800">📊 Reporte Comparativo - Campañas Meta Ads</h1>
            <p className="text-gray-600 mt-2">Generado el {new Date().toLocaleDateString('es-MX')}</p>
          </div>

          {periodo1Data.length > 0 && periodo2Data.length > 0 && (
            <>
              <div className="bg-gradient-to-r from-blue-600 to-purple-600 rounded-xl shadow-lg p-6 mb-8 text-white">
                <h2 className="text-xl font-bold mb-4">📊 Resumen Ejecutivo</h2>
                <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                  <div>
                    <div className="text-sm opacity-90">Cambio en Gasto</div>
                    <div className="text-3xl font-bold">
                      {parseFloat(calcularVariacion(totalesPeriodo2.gasto, totalesPeriodo1.gasto)) > 0 ? '+' : ''}
                      {calcularVariacion(totalesPeriodo2.gasto, totalesPeriodo1.gasto)}%
                    </div>
                  </div>
                  <div>
                    <div className="text-sm opacity-90">Cambio en Resultados</div>
                    <div className="text-3xl font-bold">
                      {parseFloat(calcularVariacion(totalesPeriodo2.resultados, totalesPeriodo1.resultados)) > 0 ? '+' : ''}
                      {calcularVariacion(totalesPeriodo2.resultados, totalesPeriodo1.resultados)}%
                    </div>
                  </div>
                  <div>
                    <div className="text-sm opacity-90">Cambio en Eficiencia</div>
                    <div className="text-3xl font-bold">
                      {parseFloat(calcularVariacion(metricasP2.costePorResultado, metricasP1.costePorResultado)) > 0 ? '+' : ''}
                      {calcularVariacion(metricasP2.costePorResultado, metricasP1.costePorResultado)}%
                    </div>
                  </div>
                </div>
              </div>

              <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
                <MetricCard 
                  title="💰 Gasto Total"
                  value1={totalesPeriodo1.gasto}
                  value2={totalesPeriodo2.gasto}
                  icon={DollarSign}
                  format="currency"
                />
                <MetricCard 
                  title="🎯 Resultados"
                  value1={totalesPeriodo1.resultados}
                  value2={totalesPeriodo2.resultados}
                  icon={Target}
                />
                <MetricCard 
                  title="💬 Nuevos Contactos"
                  value1={totalesPeriodo1.contactos}
                  value2={totalesPeriodo2.contactos}
                  icon={MessageCircle}
                />
                <MetricCard 
                  title="👁️ Visualizaciones"
                  value1={totalesPeriodo1.visualizaciones}
                  value2={totalesPeriodo2.visualizaciones}
                  icon={Eye}
                />
                <MetricCard 
                  title="👥 Alcance"
                  value1={totalesPeriodo1.alcance}
                  value2={totalesPeriodo2.alcance}
                  icon={Users}
                />
                <MetricCard 
                  title="🖱️ Clics"
                  value1={totalesPeriodo1.clics}
                  value2={totalesPeriodo2.clics}
                  icon={MousePointerClick}
                />
              </div>

              <div className="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                <MetricCard 
                  title="📉 Coste por Resultado"
                  value1={metricasP1.costePorResultado}
                  value2={metricasP2.costePorResultado}
                  icon={DollarSign}
                  format="currency"
                  invertColors={true}
                />
                <MetricCard 
                  title="📊 CTR"
                  value1={metricasP1.ctr}
                  value2={metricasP2.ctr}
                  icon={MousePointerClick}
                  format="percent"
                />
                <MetricCard 
                  title="✅ Tasa de Conversión"
                  value1={metricasP1.tasaConversion}
                  value2={metricasP2.tasaConversion}
                  icon={Target}
                  format="percent"
                />
              </div>

              <div className="bg-white rounded-xl shadow-lg border border-gray-200 p-6 mb-8">
                <h2 className="text-xl font-semibold text-gray-800 mb-6">📈 Comparación de Métricas</h2>
                <ResponsiveContainer width="100%" height={400}>
                  <BarChart data={datosGraficoComparacion}>
                    <CartesianGrid strokeDasharray="3 3" stroke="#e5e7eb" />
                    <XAxis dataKey="metrica" stroke="#6b7280" />
                    <YAxis stroke="#6b7280" />
                    <Tooltip contentStyle={{ backgroundColor: '#fff', border: '1px solid #e5e7eb', borderRadius: '8px' }} />
                    <Legend />
                    <Bar dataKey="Período 1" fill="#3b82f6" radius={[8, 8, 0, 0]} />
                    <Bar dataKey="Período 2" fill="#8b5cf6" radius={[8, 8, 0, 0]} />
                  </BarChart>
                </ResponsiveContainer>
              </div>

              <div className="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
                <div className="bg-white rounded-xl shadow-lg border border-gray-200 p-6">
                  <h2 className="text-xl font-semibold text-gray-800 mb-6">💵 Coste por Resultado</h2>
                  <ResponsiveContainer width="100%" height={300}>
                    <BarChart data={todasCampanas} layout="vertical">
                      <CartesianGrid strokeDasharray="3 3" stroke="#e5e7eb" />
                      <XAxis type="number" stroke="#6b7280" />
                      <YAxis dataKey="nombre" type="category" width={100} stroke="#6b7280" />
                      <Tooltip contentStyle={{ backgroundColor: '#fff', border: '1px solid #e5e7eb', borderRadius: '8px' }} />
                      <Bar dataKey="costePorResultado" fill="#22c55e" radius={[0, 8, 8, 0]} />
                    </BarChart>
                  </ResponsiveContainer>
                </div>

                <div className="bg-white rounded-xl shadow-lg border border-gray-200 p-6">
                  <h2 className="text-xl font-semibold text-gray-800 mb-6">🎯 Resultados por Campaña</h2>
                  <ResponsiveContainer width="100%" height={300}>
                    <BarChart data={todasCampanas}>
                      <CartesianGrid strokeDasharray="3 3" stroke="#e5e7eb" />
                      <XAxis dataKey="nombre" stroke="#6b7280" angle={-45} textAnchor="end" height={100} />
                      <YAxis stroke="#6b7280" />
                      <Tooltip contentStyle={{ backgroundColor: '#fff', border: '1px solid #e5e7eb', borderRadius: '8px' }} />
                      <Bar dataKey="resultados" fill="#8b5cf6" radius={[8, 8, 0, 0]} />
                    </BarChart>
                  </ResponsiveContainer>
                </div>
              </div>
            </>
          )}

          {periodo1Data.length > 0 && (
